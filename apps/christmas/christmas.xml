<?xml version="1.0" encoding="UTF-8"?>
<config>
    <application
        htmltitle=" 🤶🎅 Êtes-vous loin du Père Noël ? 🦌🦌🦌🦌 &lt;i style=&quot;color: #edab27&quot; class=&quot; mirror fas fa-sleigh&quot;&gt;&lt;/i&gt;"
        title="🤶 Êtes-vous loin du Père Noël ? 🎅"
        mouseposition="false" 
        logo="apps/christmas/img/christmas-tree.svg" 
        help="mviewer_help.html" 
        measuretools="true"
        exportpng="true" 
        style="apps/christmas/theme/themes/xmas-theme.css" 
        togglealllayersfromtheme="true"/>
    <mapoptions maxzoom="19"
        projection="EPSG:3857"
        center="1949651.4436330602, 7405120.536802564"
        zoom="4.333"
        projextent="-20037508.342789244, -20037508.342789244, 20037508.342789244, 20037508.342789244" />
  
    <baselayers style="gallery">
        <baselayer  type="OSM" id="darkmatter" label="Dark Matter" title="Carto" thumbgallery="img/basemap/darkmatter.png" 
            url="http://{a-c}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png" maxzoom="20" 
            visible="false" attribution="Map tiles by  &lt;a href='https://carto.com/attributions' target='_blank'>Carto &lt;/a>, under  &lt;a href='https://creativecommons.org/licenses/by/3.0/' target='_blank'>CC BY 3.0 &lt;/a>" />
        <baselayer  type="WMTS" id="ortho2" label="Photo aérienne IGN" title="GéoPortail" maxscale="1000" thumbgallery="img/basemap/ortho.jpg"
            visible="true" url="https://wxs.ign.fr/essentiels/geoportail/wmts" layers="ORTHOIMAGERY.ORTHOPHOTOS" format="image/jpeg" fromcapacity="false"
            attribution="&lt;a href='https://geoservices.ign.fr/services-web-decouverte' target='_blank'>&lt;img src='img/basemap/geoservices.png'>&lt;/a>" style="normal" matrixset="PM" maxzoom="22"/>
        <baselayer  type="OSM" id="positron" label="Positron" title="Carto" thumbgallery="img/basemap/positron.png" 
            url="http://{a-c}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png" maxzoom="20" 
            visible="false" attribution="Map tiles by  &lt;a href='https://carto.com/attributions' target='_blank'>Carto &lt;/a>, under  &lt;a href='https://creativecommons.org/licenses/by/3.0/' target='_blank'>CC BY 3.0 &lt;/a>" />
    </baselayers>     
    <proxy url=""/>
    <olscompletion url="https://api-adresse.data.gouv.fr/search/" type="ban" attribution="La recherche d'adresse est un service proposé par la BAN"/>
    <searchparameters bbox="false" localities="true" features="false" />
    <extensions>
        <extension type="component" id="christmas" path="apps"/>
        <extension type="javascript" src="https://rawgit.com/WeiChiaChang/Easter-egg/master/easter-eggs-collection.js"/>
    </extensions>
    <themes>
        <theme name="Données de Noël" collapsed="false" id="santa" icon="fas fa-sleigh">
            <layer 
                id="santa"
                name="Localisation du Père Noël 🤶🎅"
                visible="true"
                legendurl="apps/christmas/img/santa1.png"
                queryable="false"
                type="customlayer" style="" opacity="1"
                url="apps/christmas/customlayers/santa.js"
                attribution="Source: Maison mère du Père Noël - Santa Noth. Inc."
            />
            <layer 
                id="school"
                legendurl="apps/christmas/img/legend.png"
                name="Distance des écoles de Bretagne avec le Père Noël"
                visible="true"
                queryable="false"
                type="customlayer"
                opacity="1"
                url="apps/christmas/customlayers/school.js"
                tooltip="true"
                tooltipenabled="true"
                tooltipcontent="{{nom_etablissement}}"
                attribution="Source: Fabrique du Père Noël - Pôle Livraison - Santa Noth. Inc."
            />
        </theme>
        <theme name="Découpages territoriaux"  collapsed="true" id="territoire" icon="fas fa-gifts">
			<layer id="commune" name="Commune" visible="false" queryable="false" 
                fields="nom_geo" aliases="Nom" 
                type="customlayer" style="" opacity="1" legendurl="https://kartenn.region-bretagne.fr/kartoviz/apps/region/territoire/img/commune.png" 
                url="https://kartenn.region-bretagne.fr/kartoviz/apps/region/territoire/customlayers/commune.js" 
                tooltip="true" tooltipenabled="false"
                attribution="Source: GéoBretagne" 
                metadata="https://geobretagne.fr/geonetwork/srv/eng/catalog.search?node=srv#/metadata/b08e6cb1-236c-49b7-88f9-42b500d274d5" 
                metadata-csw="https://geobretagne.fr/geonetwork/srv/eng/csw?SERVICE=CSW&amp;VERSION=2.0.2&amp;REQUEST=GetRecordById&amp;elementSetName=full&amp;ID=b08e6cb1-236c-49b7-88f9-42b500d274d5"/>
            <layer id="epci" name="Intercommunalité" visible="true" queryable="false" 
                fields="nom_geo" aliases="Nom" toplayer="false"
                type="customlayer" style="" opacity="1" legendurl="https://kartenn.region-bretagne.fr/kartoviz/apps/region/territoire/img/epci.png" 
                url="https://kartenn.region-bretagne.fr/kartoviz/apps/region/territoire/customlayers/epci.js" 
                tooltip="true" tooltipenabled="false"
                attribution="Source: GéoBretagne" 
                metadata="https://geobretagne.fr/geonetwork/srv/eng/catalog.search?node=srv#/metadata/2298d744-49cb-4fcb-9487-26f916fecdff" 
                metadata-csw="https://geobretagne.fr/geonetwork/srv/eng/csw?SERVICE=CSW&amp;VERSION=2.0.2&amp;REQUEST=GetRecordById&amp;elementSetName=full&amp;ID=2298d744-49cb-4fcb-9487-26f916fecdff"/>           
        </theme>

    </themes>
</config>
